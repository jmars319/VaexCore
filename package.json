{
  "name": "vaexcore",
  "version": "0.1.0",
  "private": true,
  "description": "VaexCore is a quiet Twitch operations bot for commands, moderation, giveaways, and stream control without the usual clutter.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:local": "tsx src/dev/local.ts",
    "setup": "tsx src/setup/server.ts",
    "dev:app-config": "node scripts/run-live-from-app-config.mjs",
    "app:dev": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "app:build": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac dir && node scripts/install-electron-better-sqlite3.mjs",
    "app:dist": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac dir && node scripts/install-electron-better-sqlite3.mjs && node scripts/build-mac-dmg-from-app.mjs",
    "app:zip": "npm run app:build && node scripts/package-unsigned-mac.mjs",
    "check:env": "tsx src/cli/checkEnv.ts",
    "build": "tsc && esbuild src/setup/server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-bundle/setup-server.js && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-bundle/live-bot.js && node scripts/copy-setup-ui.mjs",
    "release:check": "node scripts/verify-release-metadata.mjs",
    "release:unsigned": "node scripts/release-unsigned.mjs",
    "smoke:tester-guide": "node scripts/smoke-tester-guide.mjs",
    "smoke:tester-artifact": "node scripts/smoke-tester-artifact.mjs",
    "smoke:tester-update": "node scripts/smoke-tester-artifact.mjs --preserve-data",
    "smoke:queue": "tsx scripts/smoke-message-queue.mjs",
    "smoke:setup": "npm run build && node scripts/smoke-setup-ui.mjs",
    "smoke:giveaway": "npm run build && node scripts/smoke-giveaway-readiness.mjs",
    "smoke:token-refresh": "npm run build && node scripts/smoke-token-refresh.mjs",
    "smoke:diagnostics": "npm run build && node scripts/smoke-diagnostics.mjs",
    "smoke:clean-install": "npm run build && node scripts/smoke-clean-install.mjs",
    "smoke:unsigned-release": "npm run app:zip && node scripts/smoke-unsigned-release.mjs",
    "smoke:cli-env": "npm run build && tsx scripts/smoke-cli-env-bootstrap.mjs",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.vaexil.vaexcore",
    "productName": "VaexCore",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "dist-bundle/**/*",
      "electron/**/*",
      "assets/icon.icns",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "VaexCore-${version}-${arch}.${ext}"
    }
  }
}
