{
  "name": "vaexcore",
  "version": "0.1.0",
  "private": true,
  "description": "VaexCore is a quiet Twitch operations bot for commands, moderation, giveaways, and stream control without the usual clutter.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:local": "tsx src/dev/local.ts",
    "check:env": "tsx src/cli/checkEnv.ts",
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
