{
  "name": "vaexcore",
  "version": "0.1.0",
  "private": true,
  "description": "VaexCore is a quiet Twitch operations bot for commands, moderation, giveaways, and stream control without the usual clutter.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:local": "tsx src/dev/local.ts",
    "setup": "tsx src/setup/server.ts",
    "app:dev": "npm run build && electron .",
    "app:build": "npm run build && electron-builder --mac dir",
    "app:dist": "npm run build && electron-builder --mac dmg",
    "check:env": "tsx src/cli/checkEnv.ts",
    "build": "tsc && esbuild src/setup/server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-bundle/setup-server.js",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.vaexil.vaexcore",
    "productName": "VaexCore",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "dist-bundle/**/*",
      "electron/**/*",
      "assets/icon.icns",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "VaexCore-${version}-${arch}.${ext}"
    }
  }
}
