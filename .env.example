VAEXCORE_MODE=live
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_USER_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=
TWITCH_BROADCASTER_USER_ID=
TWITCH_BOT_USER_ID=

# Optional
COMMAND_PREFIX=!
LOG_LEVEL=info
VAEXCORE_DEBUG=false
TWITCH_EVENTSUB_URL=wss://eventsub.wss.twitch.tv/ws
DATABASE_URL=file:./data/vaexcore.sqlite

# Token notes:
# - Use the bot account's user access token.
# - Do not include the oauth: prefix.
# - Required scopes for Milestone 1: user:read:chat user:write:chat.
# - TWITCH_CLIENT_SECRET and TWITCH_REFRESH_TOKEN are optional but recommended.
#   When both are present, npm run check:env or npm run dev imports them into
#   the local OAuth store so VaexCore can refresh expired access tokens.
